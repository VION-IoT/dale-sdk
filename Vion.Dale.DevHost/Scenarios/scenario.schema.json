{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vion.swiss/dale/scenario.schema.json",
  "title": "Dale DevHost scenario file (RFC 0006, vocabulary v1)",
  "description": "A git-committed description of a manual-test scenario: setup, ordered stimuli, watch list, human judgments. The generic structural schema shipped with Vion.Dale.DevHost; 'dale scenario schema' (R4) emits a per-project variant enriched with the topology's actual block names and property identifiers.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "topology"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1, "description": "Vocabulary version. Runners reject unknown versions loudly; evolution is by version bump." },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "description": "URL-safe slug; must match the file name (<id>.scenario.json). Deep-link route: #/scenario/{id}."
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "topology": {
      "type": "string",
      "description": "The topology id this scenario expects (a C# preset's declared name or a topology file id). Mismatch blocks the run."
    },
    "specs": { "type": "array", "items": { "type": "string" }, "description": "Free-form trace ids for the scenario as a whole (consumer policy, e.g. AC-EM-23)." },
    "setup": {
      "type": "array",
      "description": "Staging entries, applied in file order before steps; keep them order-independent and idempotent. No waits.",
      "items": { "$ref": "#/$defs/setupEntry" }
    },
    "steps": {
      "type": "array",
      "description": "Ordered stimuli and outcome waits; order is semantically significant.",
      "items": { "$ref": "#/$defs/step" }
    },
    "watch": {
      "type": "array",
      "items": { "$ref": "#/$defs/namePath" },
      "description": "Name paths the Player pins as live tiles; validated up front on every run (a watch-only scenario smokes renames)."
    },
    "judge": {
      "type": "array",
      "description": "Human-judgment checklist items. v1 has no auto-asserting checks.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "spec": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "namePath": {
      "type": "string",
      "pattern": "^[^.]+\\.[^.]+(\\.[^.]+)?$",
      "description": "Block.Property (when unambiguous within the block) or Block.Service.Property (the qualified form for multi-service blocks)."
    },
    "value": {
      "description": "A scalar, an enum member name (case-sensitive string), a complete struct/array literal, or null (nullable properties)."
    },
    "comparand": {
      "not": { "type": ["object", "array"] },
      "description": "A scalar, enum member name, or null — structs/arrays are not comparable in v1."
    },
    "stepCommon": {
      "label": { "type": "string", "description": "Shown in the Player and in reports." },
      "spec": { "type": "string", "description": "Free-form trace id for this step." }
    },
    "setStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["set", "value"],
      "properties": {
        "label": { "$ref": "#/$defs/stepCommon/label" },
        "spec": { "$ref": "#/$defs/stepCommon/spec" },
        "set": { "$ref": "#/$defs/namePath" },
        "value": { "$ref": "#/$defs/value" }
      }
    },
    "digitalInputStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digitalInput", "value"],
      "properties": {
        "label": { "$ref": "#/$defs/stepCommon/label" },
        "spec": { "$ref": "#/$defs/stepCommon/spec" },
        "digitalInput": { "$ref": "#/$defs/contractRef" },
        "value": { "type": "boolean" }
      }
    },
    "analogInputStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analogInput", "value"],
      "properties": {
        "label": { "$ref": "#/$defs/stepCommon/label" },
        "spec": { "$ref": "#/$defs/stepCommon/spec" },
        "analogInput": { "$ref": "#/$defs/contractRef" },
        "value": { "type": "number" }
      }
    },
    "waitUntilStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waitUntil"],
      "properties": {
        "label": { "$ref": "#/$defs/stepCommon/label" },
        "spec": { "$ref": "#/$defs/stepCommon/spec" },
        "waitUntil": {
          "type": "object",
          "additionalProperties": false,
          "required": ["property"],
          "properties": {
            "property": { "$ref": "#/$defs/namePath" },
            "above": { "type": "number" },
            "below": { "type": "number" },
            "equals": { "$ref": "#/$defs/comparand" },
            "notEquals": { "$ref": "#/$defs/comparand" },
            "tolerance": { "type": "number", "minimum": 0, "description": "Only with a numeric equals." }
          },
          "oneOf": [
            { "required": ["above"] },
            { "required": ["below"] },
            { "required": ["equals"] },
            { "required": ["notEquals"] }
          ]
        },
        "timeoutSeconds": { "type": "number", "exclusiveMinimum": 0, "default": 20 }
      }
    },
    "waitStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wait"],
      "properties": {
        "label": { "$ref": "#/$defs/stepCommon/label" },
        "spec": { "$ref": "#/$defs/stepCommon/spec" },
        "wait": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seconds"],
          "properties": {
            "seconds": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      },
      "description": "Fixed pause for stimulus pacing (ramps, dwell times). Use wait to shape inputs, waitUntil to await outputs."
    },
    "contractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block", "contract"],
      "properties": {
        "block": { "type": "string" },
        "contract": { "type": "string" }
      }
    },
    "setupEntry": {
      "oneOf": [
        { "$ref": "#/$defs/setStep" },
        { "$ref": "#/$defs/digitalInputStep" },
        { "$ref": "#/$defs/analogInputStep" }
      ]
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/setStep" },
        { "$ref": "#/$defs/digitalInputStep" },
        { "$ref": "#/$defs/analogInputStep" },
        { "$ref": "#/$defs/waitUntilStep" },
        { "$ref": "#/$defs/waitStep" }
      ]
    }
  }
}
