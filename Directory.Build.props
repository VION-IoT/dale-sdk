<Project>

    <PropertyGroup>
        <!-- Version fallback for local builds. CI overrides via -p:Version=x.y.z from the git tag. -->
        <Version Condition="'$(Version)' == ''">0.0.0-local</Version>
    </PropertyGroup>

    <PropertyGroup Label="Package metadata">
        <Authors>Vion IoT</Authors>
        <Company>Vion IoT</Company>
        <Copyright>Copyright (c) Vion IoT</Copyright>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/vion-iot/dale-sdk</PackageProjectUrl>
        <RepositoryUrl>https://github.com/vion-iot/dale-sdk</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
    </PropertyGroup>

    <PropertyGroup Label="Source Link &amp; symbol packages">
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <DebugType>portable</DebugType>
        <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All"/>
    </ItemGroup>

    <!--
        MSTEST0001 asks every test project to declare its parallelization policy explicitly.
        Many tests here share static state (DaleConsole.JsonMode etc.), so [DoNotParallelize] is
        the safe default. Apply via AssemblyAttribute so individual projects don't each carry
        a boilerplate AssemblyInfo.cs.
    -->
    <ItemGroup Condition="'$(IsTestProject)' == 'true'">
        <AssemblyAttribute Include="Microsoft.VisualStudio.TestTools.UnitTesting.DoNotParallelize"/>
    </ItemGroup>

</Project>

