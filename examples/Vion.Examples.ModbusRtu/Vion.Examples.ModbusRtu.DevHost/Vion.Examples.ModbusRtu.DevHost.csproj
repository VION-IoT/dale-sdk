<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>false</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <!-- Published DevHost UI by default; `dotnet build -p:DaleLocalSource=true` serves the local working-tree
         DevHost.Web (and, via the referenced example project, the working-tree SDK). -->
    <ItemGroup Condition="'$(DaleLocalSource)' != 'true'">
        <PackageReference Include="Vion.Dale.DevHost.Web" Version="0.9.11"/>
    </ItemGroup>
    <ItemGroup Condition="'$(DaleLocalSource)' == 'true'">
        <ProjectReference Include="..\..\..\Vion.Dale.DevHost.Web\Vion.Dale.DevHost.Web.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Vion.Examples.ModbusRtu\Vion.Examples.ModbusRtu.csproj"/>
    </ItemGroup>
</Project>